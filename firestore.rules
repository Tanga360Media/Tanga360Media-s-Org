rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    // Note: Updated for safe and reliable phone number authentication.
    function isVerified() { return isSignedIn(); }
    
    // Admin check: Look up role in users collection
    function isAdmin() { 
      return isVerified() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'ADMIN'; 
    }
    
    function isOwner(uid) { return isSignedIn() && request.auth.uid == uid; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }

    // --- Entity Validations ---
    function isValidUser(data) {
      return data.email is string && data.email.size() <= 100 
          && data.role in ['ADMIN', 'TEAM_MANAGER']
          && (data.displayName is string && data.displayName.size() <= 100)
          && (!('teamId' in data) || data.teamId is string)
          && (!('photoURL' in data) || data.photoURL is string);
    }

    function isValidTeam(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() <= 100
          && data.managerId is string && data.managerId == request.auth.uid
          && data.paymentStatus in ['PENDING', 'CONFIRMED', 'REJECTED']
          && data.paymentMethod is string
          && data.createdAt is string
          && data.isApproved is bool
          && (!('logoUrl' in data) || data.logoUrl is string)
          && (!('paymentProofUrl' in data) || data.paymentProofUrl is string);
    }

    function isValidPlayer(data) {
      return data.name is string && data.name.size() <= 100
          && data.teamId is string
          && data.position is string
          && data.jerseyNumber is int
          && data.photoUrl is string;
    }

    function isValidStaff(data) {
      return data.name is string && data.name.size() <= 100
          && data.teamId is string
          && data.role is string
          && data.photoUrl is string;
    }

    // --- Match Rules ---

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isVerified() && isOwner(userId) && isValidUser(incoming()) 
                     && incoming().role == 'TEAM_MANAGER'; 
      allow update: if isVerified() && isOwner(userId) && isValidUser(incoming()) 
                     && (
                       // Action: Update profile or team link
                       incoming().diff(existing()).affectedKeys().hasAny(['displayName', 'photoURL', 'teamId']) &&
                       incoming().role == existing().role
                     );
    }

    match /teams/{teamId} {
      allow read: if true;
      allow create: if isVerified() && isValidTeam(incoming()) && incoming().isApproved == false;
      allow update: if isVerified() && (
        isAdmin() || 
        (existing().managerId == request.auth.uid && isValidTeam(incoming()) &&
         incoming().diff(existing()).affectedKeys().hasOnly(['name', 'logoUrl', 'paymentProofUrl', 'paymentMethod']))
      );
    }

    match /players/{playerId} {
      allow read: if true;
      allow create: if isVerified() && isValidPlayer(incoming()) 
                     && get(/databases/$(database)/documents/teams/$(incoming().teamId)).data.managerId == request.auth.uid;
      allow delete, update: if isVerified() 
                     && get(/databases/$(database)/documents/teams/$(existing().teamId)).data.managerId == request.auth.uid;
    }

    match /staff/{staffId} {
      allow read: if true;
      allow create: if isVerified() && isValidStaff(incoming()) 
                     && get(/databases/$(database)/documents/teams/$(incoming().teamId)).data.managerId == request.auth.uid;
      allow delete, update: if isVerified() 
                     && get(/databases/$(database)/documents/teams/$(existing().teamId)).data.managerId == request.auth.uid;
    }

    match /matches/{matchId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /registrationPeriods/{periodId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
